# ── Python ────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.egg-info/
dist/
build/
.venv/
venv/
*.pyo

# ── Environment ───────────────────────────────────────────────────────────────
.env
.env.local
.env.*.local
# Keep .env.example (template for new devs)

# ── Data (immutable raw fetch — large files, not needed in repo) ───────────────
backend/data/raw/*.json
backend/data/raw/.fetch_checkpoint.json

# ── Database / LangGraph state ────────────────────────────────────────────────
*.db
*.db-shm
*.db-wal
*.sqlite

# ── Docker volumes (managed by Docker, not git) ───────────────────────────────
qdrant_data/

# ── Logs & PID files ──────────────────────────────────────────────────────────
*.log
*.pid
.logs/

# ── Node / Next.js ────────────────────────────────────────────────────────────
node_modules/
.next/
out/
frontend/.next/
frontend/out/
frontend/node_modules/
# Keep package.json, package-lock.json, tsconfig.json etc.

# ── TypeScript build cache ────────────────────────────────────────────────────
*.tsbuildinfo

# ── IDE ────────────────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo

# ── OS ────────────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
*~

# ── MyPy / Ruff / coverage cache ──────────────────────────────────────────────
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/
.pytest_cache/

# ── Evaluation results (generated artifacts, not source) ─────────────────────
backend/eval/results/

