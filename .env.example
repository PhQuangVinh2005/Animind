# ── ShopAIKey — OpenAI-compatible provider ────────────────────────────────────
# Used for: GPT-4o-mini chat completions + text-embedding-3-small embeddings
# Register: https://shopaikey.com  →  Dashboard → API Keys
# Client config:
#   OpenAI(
#       api_key=SHOPAIKEY_API_KEY,
#       base_url=SHOPAIKEY_BASE_URL,
#       default_headers={"User-Agent": "Mozilla/5.0 ..."}
#   )
SHOPAIKEY_API_KEY=sk-your-shopaikey-here
SHOPAIKEY_BASE_URL=https://api.shopaikey.com/v1
OPENAI_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# ── Qdrant vector DB ──────────────────────────────────────────────────────────
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=anime

# ── vLLM Reranker ─────────────────────────────────────────────────────────────
RERANKER_URL=http://localhost:8001
RERANKER_MODEL=Qwen/Qwen3-Reranker-0.6B

# ── AniList OAuth2 ────────────────────────────────────────────────────────────
# Register your app at: https://anilist.co/settings/developer
# Public anime data (Page/Media query) does NOT require authentication.
# CLIENT_ID + CLIENT_SECRET are needed for user-specific endpoints/mutations.
# ACCESS_TOKEN is a long-lived JWT (1 year, no refresh token support).
ANILIST_API_URL=https://graphql.anilist.co
ANILIST_CLIENT_ID=your-client-id
ANILIST_CLIENT_SECRET=your-client-secret
ANILIST_ACCESS_TOKEN=

# ── CORS ──────────────────────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:3000
